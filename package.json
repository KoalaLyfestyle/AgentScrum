{
  "name": "agentscrum",
  "version": "0.2.0",
  "description": "Scrum management for agent swarms — MCP-native sprint state",
  "type": "module",
  "bin": {
    "scrum": "./bin/scrum.cjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dev:dashboard": "cd dashboard && npm run dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^9.4.3",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.30.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "drizzle-kit": "^0.21.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.worktrees/"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": {
            "exclude": [
              "/.worktrees/"
            ]
          }
        }
      ]
    }
  }
}
