# Environment variable schema for AgentScrum
# Copy to .env and fill in values as needed

# @type=string @optional — SQLite file path (default: ./agentscrum.db)
SCRUM_DB_PATH=

# @type=number @optional — active project ID passed to MCP server
SCRUM_PROJECT_ID=

# @type=string @optional — Obsidian vault root for export-sprint.ts
OBSIDIAN_VAULT_PATH=

# @type=number @optional — reserved for future multi-agent coordination
MAX_AGENTS=

# @type=boolean @optional — reserved for future ML cost predictor
ENABLE_ML_PREDICTOR=false
